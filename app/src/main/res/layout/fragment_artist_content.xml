<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Fragments.ArtistContentFragment"
    android:id="@+id/artist_container_content"
    android:background="@drawable/main_bg">

    <RelativeLayout
        android:id="@+id/artist_header_panel"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_alignParentTop="true">

        <ImageView
            android:id="@+id/artist_back_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_back_btn" />

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/artist_name_panel"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_below="@+id/artist_header_panel">

        <TextView
            android:id="@+id/artist_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:text="Artist name"
            android:textColor="@color/white" />

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/artist_info"
        android:layout_width="match_parent"
        android:layout_height="108dp"
        android:orientation="horizontal"
        android:layout_below="@+id/artist_name_panel">

<!--        <androidx.cardview.widget.CardView-->
<!--            android:id="@+id/album_cover_holder"-->
<!--            android:layout_width="72dp"-->
<!--            android:layout_height="108dp"-->
<!--            android:layout_marginStart="12dp"-->
<!--            android:layout_alignParentStart="true"-->
<!--            app:cardCornerRadius="5dp"-->
<!--            app:cardElevation="4dp">-->

<!--            <ImageView-->
<!--                android:id="@+id/album_cover"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="match_parent"-->
<!--                android:scaleType="centerCrop"-->
<!--                android:adjustViewBounds="true"/>-->

<!--        </androidx.cardview.widget.CardView>-->

        <ImageView
            android:id="@+id/album_cover"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:contentDescription="image"
            android:adjustViewBounds="true"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView_artist_albums"
            android:layout_width="match_parent"
            android:layout_height="108dp"
            android:layout_centerVertical="true"
            android:layout_marginHorizontal="12dp"
            android:layout_toEndOf="@+id/album_cover" />

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/artist_album_panel"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_below="@+id/artist_info">

        <TextView
            android:id="@+id/total_albums"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:text="XX"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/total_albums_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginEnd="12dp"
            android:layout_toEndOf="@+id/total_albums"
            android:text=" songs"
            android:textColor="@color/white" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toStartOf="@+id/total_song"
            android:layout_toEndOf="@+id/total_albums_text">

            <TextView
                android:id="@+id/album_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:singleLine="true"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:scrollHorizontally="true"
                android:text="All"
                android:textColor="@color/white" />

        </RelativeLayout>

        <TextView
            android:id="@+id/total_song"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@+id/total_song_text"
            android:text="XX"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/total_song_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="12dp"
            android:text=" albums"
            android:textColor="@color/white" />

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/artist_album_panel"
        android:orientation="horizontal">

        <androidx.cardview.widget.CardView
            android:id="@+id/search_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@+id/quick_shuffle"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="5dp"
            app:cardElevation="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search?..."
                android:textSize="16sp"
                android:padding="6dp"
                android:background="@drawable/main_bg"/>

        </androidx.cardview.widget.CardView>

        <ImageView
            android:id="@+id/quick_shuffle"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_toStartOf="@id/sort"
            android:layout_centerVertical="true"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_shuffle_on" />

        <ImageView
            android:id="@+id/sort"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="18dp"
            android:src="@drawable/ic_sort" />

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/album_songs"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/panel"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView_artist_songs"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </LinearLayout>

</RelativeLayout>