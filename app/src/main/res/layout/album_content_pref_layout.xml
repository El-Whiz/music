<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/popup_bg">

    <TextView
        android:id="@+id/title_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sort"
        android:textStyle="bold"
        android:textSize="18dp"
        android:textColor="@color/white"
        android:layout_marginVertical="12dp"
        android:layout_centerVertical="true"/>

    <TextView
        android:id="@+id/title_ascending"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Title - ascending"
        android:textSize="16sp"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/title_descending"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Title - descending"
        android:textSize="16sp"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/duration_ascending"
        android:layout_width="wrap_content"
        android:textSize="16sp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Duration - ascending"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/duration_descending"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:text="Duration - descending"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/size_ascending"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:text="Size - ascending"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/size_descending"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:text="Size - descending"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/date_ascending"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:text="Date - ascending"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/date_descending"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:text="Date - descending"
        android:textColor="@color/white" />

</LinearLayout>