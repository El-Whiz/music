<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".EditTagsActivity"
    android:background="@drawable/main_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <RelativeLayout
            android:id="@+id/edit_tag_header"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <TextView
                android:id="@+id/edit_tag_header_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Tag Editor"
                android:textColor="@color/white"
                android:layout_centerInParent="true"
                android:layout_centerVertical="true"/>

            <ImageView
                android:id="@+id/edit_done_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_check"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginRight="12dp"/>

            <ImageView
                android:id="@+id/edit_back_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_back_btn"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginLeft="12dp"/>

        </RelativeLayout>

        <ImageView
            android:id="@+id/edit_tag_art"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_marginTop="20dp"
            android:padding="12dp"
            android:src="@drawable/default_art"/>

        <EditText
            android:id="@+id/edit_tag_title"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:layout_marginLeft="30dp"
            android:layout_marginRight="30dp"
            android:padding="12dp"
            android:hint="title"
            android:textColorHint="@color/white"
            android:textColor="@color/white"/>
        <EditText
            android:id="@+id/edit_tag_album"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:layout_marginLeft="30dp"
            android:layout_marginRight="30dp"
            android:padding="12dp"
            android:hint="album"
            android:textColorHint="@color/white"
            android:textColor="@color/white"/>
        <EditText
            android:id="@+id/edit_tag_artist"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:layout_marginLeft="30dp"
            android:layout_marginRight="30dp"
            android:padding="12dp"
            android:hint="artist"
            android:textColorHint="@color/white"
            android:textColor="@color/white"/>
        <EditText
            android:id="@+id/edit_tag_genre"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:layout_marginLeft="30dp"
            android:layout_marginRight="30dp"
            android:padding="12dp"
            android:hint="genre"
            android:textColorHint="@color/white"
            android:textColor="@color/white"/>
        <EditText
            android:id="@+id/edit_tag_year"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:layout_marginLeft="30dp"
            android:layout_marginRight="30dp"
            android:padding="12dp"
            android:hint="year"
            android:textColorHint="@color/white"
            android:textColor="@color/white"/>

    </LinearLayout>

</ScrollView>