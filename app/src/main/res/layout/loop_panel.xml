<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="24dp"
    android:padding="24dp"
    android:background="@drawable/main_bg">

    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loop"
            android:textColor="@color/white"/>

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/from_values_holder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/header">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="From..."
            android:textColor="@color/white"
            android:layout_centerVertical="true"/>

        <EditText
            android:id="@+id/start_position_seconds"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:hint="sec"
            android:inputType="phone" />

        <EditText
            android:id="@+id/start_position_minutes"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/start_position_seconds"
            android:hint="min"
            android:inputType="phone" />

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/to_values_holder"
        android:layout_below="@+id/from_values_holder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="To..."
            android:textColor="@color/white"
            android:layout_centerVertical="true"/>

        <EditText
            android:id="@+id/end_position_seconds"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:hint="sec"
            android:inputType="phone"
            android:layout_alignParentEnd="true"/>

        <EditText
            android:id="@+id/end_position_minutes"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:hint="min"
            android:inputType="phone"
            android:layout_toStartOf="@+id/end_position_seconds"/>

    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/to_values_holder"
        android:layout_marginTop="1dp">

        <TextView
            android:id="@+id/error_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="ERROR"
            android:textColor="#D32F2F"
            android:visibility="invisible" />

        <ImageView
            android:id="@+id/extract_loop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:layout_toStartOf="@id/done_btn"
            android:visibility="gone"
            android:src="@drawable/ic_save" />

        <ImageView
            android:id="@+id/done_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_check" />

    </RelativeLayout>

</RelativeLayout>