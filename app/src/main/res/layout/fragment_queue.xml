<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fragment_queue"
    tools:context=".Fragments.QueueFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/main_bg">

        <androidx.cardview.widget.CardView
            android:id="@+id/search_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/album_info"
            android:layout_marginHorizontal="12dp"
            android:layout_marginVertical="6dp"
            app:cardCornerRadius="5dp"
            app:cardElevation="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search?..."
                android:textSize="16sp"
                android:padding="6dp"
                android:background="@drawable/main_bg"/>

        </androidx.cardview.widget.CardView>

        <RelativeLayout
            android:id="@+id/header_queue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="6dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_arrow_drop_down">
            </ImageView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="See Queues?"
                android:textColor="@color/white"
                android:padding="8dp">

            </TextView>

        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="6dp">

            <TextView
                android:id="@+id/total_items"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="xx songs"
                android:layout_centerVertical="true"
                android:textColor="@color/white"
                android:layout_marginHorizontal="18dp"/>

            <ImageView
                android:id="@+id/queue_play_pause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_pause_white">
            </ImageView>

            <TextView
                android:id="@+id/queue_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/total_items"
                android:layout_toEndOf="@+id/queue_play_pause"
                android:text="Queue title"
                android:layout_centerVertical="true"
                android:singleLine="true"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:scrollHorizontally="true"
                android:textColor="@color/white"
                android:layout_marginHorizontal="8dp"/>

        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView_queue"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/search_shii" />

    </LinearLayout>

</RelativeLayout>