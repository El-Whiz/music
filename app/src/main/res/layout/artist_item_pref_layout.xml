<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/popup_bg">

    <TextView
        android:id="@+id/title_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sort"
        android:textStyle="bold"
        android:textSize="18dp"
        android:textColor="@color/white"
        android:layout_marginVertical="12dp"
        android:layout_centerVertical="true"/>

    <TextView
        android:id="@+id/artist_ascending"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:text="Artist - ascending"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/artist_descending"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:textSize="16sp"
        android:text="Artist - descending"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/total_songs_ascending"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:text="Total songs - ascending"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/total_songs_descending"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:text="Total songs - descending"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/albums_ascending"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:text="Total albums - ascending"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/albums_descending"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:text="Total albums - descending"
        android:textColor="@color/white" />

